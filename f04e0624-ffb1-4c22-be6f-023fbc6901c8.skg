title: how
pid: f04e0624-ffb1-4c22-be6f-023fbc6901c8
body: |2-
  { pkgs ? import <nixpkgs> {} }:

  pkgs.mkShell {
    buildInputs = with pkgs; [
      # Rust development
      rustc
      cargo
      rustfmt
      clippy

      # Required for Tantivy
      pkg-config
      openssl
      openssl.dev
    ];

    # Environment variables
    shellHook = ''
      export RUST_BACKTRACE=1
      export PKG_CONFIG_PATH="${pkgs.openssl.dev}/lib/pkgconfig:$PKG_CONFIG_PATH"
    '';
  }
