title: let handle = trpl::spawn_task(async {
pid: f68f0d43-18ac-48ad-b81a-b666552d9fcf
body: |2-
      for i in 1..10 {
          println!("hi number {i} from the first task!");
          trpl::sleep(Duration::from_millis(500)).await;
      }
  });

  for i in 1..5 {
      println!("hi number {i} from the second task!");
      trpl::sleep(Duration::from_millis(500)).await;
  }

  handle.await.unwrap();
