title: References can be passed without changing ownership of the referent.
pid: f461cd5b-c164-4dde-a5d2-3128d9f90037
body: |2-
  fn main() {
      let s1 = String::from("hello");

      let len = calculate_length(&s1);

      println!("The length of '{s1}' is {len}.");
  }

  fn calculate_length(s: &String) -> usize {
      s.len()
  }
