title: '[[id:840a9c58-8c07-46ba-a37f-efeb4cb0821e][superimpose a swung echo]]'
pid: 67a8ec9f-3565-4fe6-9f9a-f27ed9dab644
body: |2-
  #+BEGIN_SRC haskell
  d1 $ superimpose
        ( late (2/12) .
  	(|* distort 0.3) .
  	(|* speed "[3,5]") .
  	(|* gain 0.7) )
        $ s "<bd bass> hh sn:1 <<bleep <numbers:1 numbers:2>> hh>" |* slow 16 (speed "[1!3 0.8] [0.7 0.6]")
  #+END_SRC
