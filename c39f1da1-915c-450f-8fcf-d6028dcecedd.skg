title: use `move` to stick an ordinary type into `Ur`
pid: c39f1da1-915c-450f-8fcf-d6028dcecedd
body: |2-
  class Dupable a => Movable a where
      move :: a %1 -> Ur a

  instance Movable Bool where
      move True  = Ur True
      move False = Ur False
contains:
- 3d51fd2a-1b56-4991-9ae2-170f7734c5b2
